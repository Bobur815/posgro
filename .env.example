# ===========================================
# Grocery POS - Environment Configuration
# ===========================================

# App Mode (pos | server)
APP_MODE=pos

# ===========================================
# Database Configuration
# ===========================================
# For POS Terminal (SQLite):
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./pos-local.db

# For VPS Server (PostgreSQL):
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/grocery_pos

# ===========================================
# POS Terminal Configuration
# ===========================================
# VPS Connection
VPS_API_URL=http://localhost:3000/api

# Terminal Identity
TERMINAL_ID=T1

# Sync Settings
SYNC_INTERVAL_MS=300000
RETRY_INTERVAL_MS=60000

# Printer (optional)
PRINTER_NAME=TM-T20II
PRINTER_TYPE=thermal

# ===========================================
# VPS Server Configuration
# ===========================================
# JWT Authentication
JWT_SECRET=your-very-secure-secret-key-minimum-32-chars
JWT_EXPIRES_IN=8h

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_ADMIN_ID=987654321

# Server
PORT=3000
NODE_ENV=development

# CORS
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ===========================================
# Debug
# ===========================================
DEBUG=false
LOG_LEVEL=info
