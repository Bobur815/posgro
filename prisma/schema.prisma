// POSGRO - Prisma Schema
// Works with PostgreSQL (VPS)
// Multi-tenant: Each store has isolated data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MULTI-TENANCY ====================

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?  @db.Text
  phone     String?
  active    Boolean  @default(true)
  aiPlan    String   @default("free") @map("ai_plan") // "free" | "paid" — AI invoice scanning tier
  balance   Decimal  @default(0) @db.Decimal(12, 4) @map("balance") // Store balance in UZS (so'm)

  subscriptionPlan      String?   @map("subscription_plan")       // "STARTER" | "PRO" | "VIP"
  subscriptionExpiresAt DateTime? @map("subscription_expires_at") // null = perpetual (VIP)

  settings  String?  @db.Text // JSON: tax rate, receipt template, etc.

  scheduledDeleteAt DateTime? @map("scheduled_delete_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  users                User[]
  categories           Category[]
  products             Product[]
  sales                Sale[]
  inventoryArrivals    InventoryArrival[]
  suppliers            Supplier[]
  supplierTransactions SupplierTransaction[]
  systemSettings       SystemSetting[]
  auditLogs            AuditLog[]
  terminalHeartbeats   TerminalHeartbeat[]
  terminalLogs         TerminalLog[]
  paynetReceipts       PaynetReceipt[]
  soldMarkingCodes     SoldMarkingCode[]
  pendingMarkingCodes  PendingMarkingCode[]

  @@map("stores")
}

// ==================== USER MANAGEMENT ====================

enum UserRole {
  SUPER_ADMIN // Can manage all stores
  ADMIN       // Store admin
  USER        // Cashier
}

model User {
  id        String   @id @default(cuid())
  storeId   String?  @map("store_id") // Null for SUPER_ADMIN
  store     Store?   @relation(fields: [storeId], references: [id])
  phone     String
  password  String   // Bcrypt hashed
  role      UserRole @default(USER)
  nameUz    String   @map("name_uz")
  nameRu    String   @map("name_ru")
  active    Boolean  @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions  UserSession[]

  @@unique([storeId, phone]) // Same phone can exist in different stores
  @@index([storeId])
  @@map("users")
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?  @map("user_agent") @db.Text
  ipAddress  String?  @map("ip_address")
  deviceName String?  @map("device_name")
  isRevoked  Boolean  @default(false) @map("is_revoked")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_sessions")
}

// ==================== PRODUCTS & INVENTORY ====================

model Category {
  id            Int        @id @default(autoincrement())
  storeId       String     @map("store_id")
  store         Store      @relation(fields: [storeId], references: [id])
  nameUz        String     @map("name_uz")
  nameRu        String     @map("name_ru")
  mxikGroupCode String?    @map("mxik_group_code") // 3-digit MXIK group, e.g. "022" — links to MxikCatalog
  active        Boolean    @default(true)
  products      Product[]
  suppliers     Supplier[]
  createdAt     DateTime   @default(now()) @map("created_at")

  @@index([storeId])
  @@index([mxikGroupCode])
  @@map("categories")
}

model Product {
  id              Int      @id @default(autoincrement())
  storeId         String   @map("store_id")
  store           Store    @relation(fields: [storeId], references: [id])
  barcode         String
  nameUz          String   @map("name_uz")
  nameRu          String   @map("name_ru")
  price           Decimal  @db.Decimal(10, 2)
  cost            Decimal? @db.Decimal(10, 2) // Purchase cost (admin only)
  stock           Decimal  @default(0) @db.Decimal(10, 3)
  minStock        Decimal  @default(0) @db.Decimal(10, 3) @map("min_stock") // Low stock alert
  unit            String   @default("шт") // шт, кг, л, etc
  categoryId      Int      @map("category_id")
  category        Category @relation(fields: [categoryId], references: [id])
  supplierId      String?  @map("supplier_id")
  supplier        Supplier? @relation("ProductSupplier", fields: [supplierId], references: [id])
  productionDate  DateTime? @map("production_date")
  expiryDate      DateTime? @map("expiry_date")
  discountPercent        Decimal?  @default(0) @db.Decimal(5, 2) @map("discount_percent")
  isOnPromotion          Boolean   @default(false) @map("is_on_promotion")
  mxik                   String?   @map("mxik") // Uzbekistan national catalog code (nullable, non-unique — multiple products can share one MXIK)
  packageCode            String?   @map("package_code") // REGOS:VCR package (unit) code from MXIK — required for fiscalizing marked goods
  active                 Boolean   @default(true)
  pendingPrice           Decimal?  @db.Decimal(10, 2) @map("pending_price")
  pendingPriceThreshold  Decimal?  @db.Decimal(10, 3) @map("pending_price_threshold")

  // Weighted product fields
  // productType: REGULAR | BULK_WEIGHTED | PREPACKAGED
  productType   String  @default("REGULAR") @map("product_type")
  internalCode  String? @map("internal_code") // 5-digit code for weighted products
  bulkQuantity  Decimal @default(0) @db.Decimal(10, 3) @map("bulk_quantity")
  minSaleQty    Decimal @default(0) @db.Decimal(10, 3) @map("min_sale_qty")
  maxSaleQty    Decimal @default(0) @db.Decimal(10, 3) @map("max_sale_qty")

  storeProductCode Int? @map("store_product_code")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sales              SaleItem[]
  inventoryMovements InventoryArrival[]

  @@unique([storeId, barcode]) // Same barcode can exist in different stores
  @@unique([storeId, internalCode]) // internalCode unique per store
  @@unique([storeId, storeProductCode]) // Per-store sequential product code
  @@index([storeId])
  @@index([storeId, mxik]) // Fast MXIK lookup per store
  @@map("products")
}

// ==================== SALES ====================

model Sale {
  id             String   @id @default(cuid())
  storeId        String   @map("store_id")
  store          Store    @relation(fields: [storeId], references: [id])
  receiptNumber  String   @map("receipt_number") // Auto-generated
  totalAmount    Decimal  @map("total_amount") @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @map("discount_amount") @db.Decimal(10, 2)
  finalAmount    Decimal  @map("final_amount") @db.Decimal(10, 2)
  paymentMethod  String   @map("payment_method") // cash, card

  cashierId   String @map("cashier_id")
  cashierName String @map("cashier_name") // Denormalized for reports
  terminalId  String @map("terminal_id") // T1, T2

  // Sync tracking
  synced   Boolean   @default(false)
  syncedAt DateTime? @map("synced_at")

  createdAt DateTime @default(now()) @map("created_at")

  items SaleItem[]

  @@unique([storeId, receiptNumber]) // Receipt numbers unique per store
  @@index([storeId])
  @@index([cashierId])
  @@index([terminalId])
  @@index([synced])
  @@index([createdAt])
  @@map("sales")
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String @map("sale_id")
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId Int?  @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])

  productName String  @map("product_name") // Denormalized
  barcode     String
  quantity    Decimal @db.Decimal(10, 3) // 1.5 kg, etc
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)

  @@map("sale_items")
}

// ==================== INVENTORY MANAGEMENT ====================

model InventoryArrival {
  id        String  @id @default(cuid())
  storeId   String  @map("store_id")
  store     Store   @relation(fields: [storeId], references: [id])
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  quantity  Decimal  @db.Decimal(10, 3)
  cost      Decimal  @db.Decimal(10, 2) // Purchase cost per unit
  totalCost Decimal  @map("total_cost") @db.Decimal(10, 2)

  supplierId String?   @map("supplier_id")
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  notes String? @db.Text

  createdBy String   @map("created_by") // User ID or Telegram ID
  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@index([productId])
  @@index([createdAt])
  @@map("inventory_arrivals")
}

model Supplier {
  id      String  @id @default(cuid())
  storeId String  @map("store_id")
  store   Store   @relation(fields: [storeId], references: [id])
  nameUz  String  @map("name_uz")
  nameRu  String  @map("name_ru")
  phone   String?
  address String? @db.Text
  active      Boolean             @default(true)
  balance     Decimal             @default(0) @db.Decimal(12, 2) // Negative = we owe them, Positive = they owe us
  paymentType SupplierPaymentType @default(IMMEDIATE) @map("payment_type")

  categories   Category[]
  arrivals     InventoryArrival[]
  products     Product[] @relation("ProductSupplier")
  transactions SupplierTransaction[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@map("suppliers")
}

// ==================== SUPPLIER TRANSACTIONS ====================

enum SupplierPaymentType {
  IMMEDIATE    // Paid on delivery (cash / card / bank transfer)
  INSTALLMENT  // Pay later (credit terms)
}

enum SupplierTransactionType {
  PURCHASE    // We received goods (increases our debt)
  PAYMENT     // We paid supplier (decreases our debt)
  RETURN      // We returned goods (decreases our debt)
  ADVANCE     // We paid in advance (supplier owes us)
  ADJUSTMENT  // Manual balance correction
}

enum SupplierPaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  INSTALLMENT
  ONE_TO_ONE    // Previous debt cleared against new purchase
}

model SupplierTransaction {
  id         String  @id @default(cuid())
  storeId    String  @map("store_id")
  store      Store   @relation(fields: [storeId], references: [id])
  supplierId String  @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  type          SupplierTransactionType
  paymentMethod SupplierPaymentMethod   @map("payment_method")
  amount        Decimal                 @db.Decimal(12, 2) // Positive = reduces our debt, Negative = increases our debt
  description   Json?

  // Reference to related entity (e.g., InventoryArrival)
  referenceId   String? @map("reference_id")
  referenceType String? @map("reference_type") // 'ARRIVAL', 'RETURN', etc.

  dueDate   DateTime? @map("due_date")
  paidAt    DateTime? @map("paid_at")

  createdBy String  @map("created_by") // User ID who created this
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([storeId])
  @@index([supplierId])
  @@index([type])
  @@index([createdAt])
  @@map("supplier_transactions")
}

// ==================== SYSTEM SETTINGS ====================

model SystemSetting {
  id      String @id @default(cuid())
  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id])
  key     String
  value   String @db.Text

  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([storeId, key]) // Same key can exist in different stores
  @@index([storeId])
  @@map("system_settings")
}

// ==================== TERMINAL HEARTBEAT ====================

model TerminalHeartbeat {
  id             String   @id @default(cuid())
  storeId        String   @map("store_id")
  store          Store    @relation(fields: [storeId], references: [id])
  terminalId     String   @map("terminal_id")
  unsyncedCount  Int      @default(0) @map("unsynced_count")
  lastSyncAt     DateTime @map("last_sync_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([storeId, terminalId])
  @@index([storeId])
  @@map("terminal_heartbeats")
}

// ==================== TERMINAL LOGS ====================

model TerminalLog {
  id         String   @id @default(cuid())
  storeId    String   @map("store_id")
  store      Store    @relation(fields: [storeId], references: [id])
  terminalId String   @map("terminal_id")
  level      String   // "info" | "warn" | "error"
  message    String   @db.Text
  timestamp  DateTime

  createdAt  DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@index([storeId, level])
  @@index([storeId, timestamp(sort: Desc)])
  @@map("terminal_logs")
}

model SiteConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

// ==================== PAYNET FISCAL RECEIPTS ====================

model PaynetReceipt {
  id            String   @id @default(cuid())
  storeId       String   @map("store_id")
  store         Store    @relation(fields: [storeId], references: [id])

  ofdUrl        String   @map("ofd_url") @db.Text
  receiptNumber String   @map("receipt_number") // `r` param from OFD URL
  terminalCode  String   @map("terminal_code")  // `t` param
  fiscalMark    String   @map("fiscal_mark")    // `s` param
  issuedAt      DateTime @map("issued_at")       // parsed from `c` param (YYYYMMDDHHmmss)

  amount        Decimal? @db.Decimal(12, 2)      // fetched from OFD page (null if parse failed)

  integrated        Boolean   @default(false)
  saleReceiptNumber String?   @map("sale_receipt_number")
  integratedAt      DateTime? @map("integrated_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([storeId, receiptNumber])
  @@index([storeId, integrated])
  @@map("paynet_receipts")
}

// ==================== MARKING CODES (Group 022 unique QR tracking) ====================

model SoldMarkingCode {
  id             String   @id @default(cuid())
  storeId        String   @map("store_id")
  store          Store    @relation(fields: [storeId], references: [id])
  code           String
  productBarcode String?  @map("product_barcode")
  terminalId     String   @map("terminal_id")
  soldAt         DateTime @default(now()) @map("sold_at")

  @@unique([storeId, code])
  @@index([storeId])
  @@map("sold_marking_codes")
}

// Group-022 marking codes sold while still IN circulation, captured for later REGOS:VCR
// fiscalization (taking them out of circulation). Synced from terminals so all terminals
// and the server share one view. `fiscalized` is reserved for the future VCR step.
model PendingMarkingCode {
  id                String    @id @default(cuid())
  storeId           String    @map("store_id")
  store             Store     @relation(fields: [storeId], references: [id])
  code              String
  productBarcode    String?   @map("product_barcode")
  saleId            String?   @map("sale_id")
  terminalId        String    @map("terminal_id")
  circulationStatus String?   @map("circulation_status")
  fiscalized        Boolean   @default(false)
  createdAt         DateTime  @default(now()) @map("created_at")

  @@unique([storeId, code])
  @@index([storeId])
  @@map("pending_marking_codes")
}

model AuditLog {
  id       String  @id @default(cuid())
  storeId  String  @map("store_id")
  store    Store   @relation(fields: [storeId], references: [id])
  userId   String  @map("user_id")
  phone    String  @map("phone")
  action   String  // "create_product", "delete_sale", etc
  entity   String  // "product", "sale", "user"
  entityId String  @map("entity_id")
  details  String? @db.Text // JSON

  createdAt DateTime @default(now()) @map("created_at")

  @@index([storeId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== MXIK CATALOG ====================

model MxikCatalog {
  id                Int      @id @default(autoincrement())
  mxikCode          String   @unique @map("mxik_code")          // 17-digit code, e.g. "02201002001001003"
  mxikName          String   @map("mxik_name") @db.Text         // Full Uzbek product name
  groupCode         String   @map("group_code")                  // "022"
  groupName         String   @map("group_name")                  // "ALKOGOLLI VA ALKOGOLSIZ ICHIMLIKLAR..."
  classCode         String   @map("class_code")                  // "02201"
  className         String   @map("class_name")                  // "Tabiiy va mineral suvlar"
  positionCode      String   @map("position_code")               // "02201002"
  positionName      String   @map("position_name")
  subPositionCode   String   @map("sub_position_code")           // "02201002001"
  subPositionName   String   @map("sub_position_name")
  brandCode         String?  @map("brand_code")                  // "02201002001001"
  brandName         String?  @map("brand_name")
  attributeName     String?  @map("attribute_name") @db.Text
  internationalCode String?  @map("international_code")          // EAN-13 barcode
  unitName          String?  @map("unit_name")
  commonUnitName    String?  @map("common_unit_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([groupCode])
  @@index([classCode])
  @@index([internationalCode])
  @@map("mxik_catalog")
}
