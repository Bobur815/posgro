# =============================================
# Grocery POS — Standalone Telegram Bot
# Copy to .env in the deployed bot directory
# =============================================

# PostgreSQL connection (same DB as the main server, exposed on host port 5434)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_VPS_IP:5434/posgro

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Public URL of the web panel shown in the bot's Web button
WEB_APP_URL=https://pos.bobur-dev.uz

APP_MODE=server
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@postgres:5432/posgro
JWT_SECRET=YOUR_JWT_SECRET
JWT_EXPIRES_IN=14h
PORT=3001
NODE_ENV=production
CORS_ORIGINS=https://pos.bobur-dev.uz,http://192.168.1.109:5173,http://192.168.1.111:5173,http://localhost:5173
WEB_APP_URL=https://pos.bobur-dev.uz
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
ASLBELGISI_API_KEY=YOUR_ASLBELGISI_KEY
PYTHON_OCR_URL=http://ocr-python:8001
UPLOADS_DIR=/app/uploads
DEBUG=false
LOG_LEVEL=info
